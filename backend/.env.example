# Niha backend — copy to .env (or just export). All optional; sensible defaults.

REGISTRY_MODE=file          # file | db  — UI write-gate; set 'db' to exercise write endpoints
SEMANTIC=1                  # 1 = embedding Level-1 classifier (DEFAULT; needs sentence-transformers) · 0 = keyword
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# NIHA_CONFIG_DIR=./config_data

# Provider keys are read ONLY as ${ENV} refs (never inline in YAML). Set as needed:
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
