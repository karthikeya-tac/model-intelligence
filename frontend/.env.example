# Frontend environment — copy to `.env` (dev) or `.env.production` (prod) and set the value.
# Vite only exposes vars prefixed with VITE_ to the app.

# Base URL of the Niha backend API. Defaults to http://localhost:8000 if unset.
# REQUIRED for production builds — otherwise the app falls back to localhost and won't load.
VITE_API_BASE_URL=http://localhost:8000
